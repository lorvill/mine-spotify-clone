generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  username  String   @unique

  playlists Playlist[]

  @@map("users")
}

model Playlist {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id])
  userId      Int      @map("user_id")

  @@map("playlists")
}

model RadioStation {
  id       Int    @id @default(autoincrement())
  title    String @unique
  subtitle String
  image    String

  @@map("radio_stations")
}

model NewRelease {
  id       Int    @id @default(autoincrement())
  title    String @unique
  subtitle String
  image    String

  @@map("new_releases")
}
