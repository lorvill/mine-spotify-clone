{
  "compilerOptions": {
    /* Базовые настройки */
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",

    /* Строгая проверка типов (рекомендуется для Prisma) */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* Совместимость */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    /* Эмиссия файлов (важно для работы npm run start) */
    "noEmit": false,
    "sourceMap": true,
    "removeComments": true,

    /* Важно для Prisma: чтобы она корректно генерировала типы */
    "declaration": true,

  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}